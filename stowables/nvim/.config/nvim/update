#!/bin/zsh

# Colors for better readability
BOLD='\033[1m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
GRAY='\033[0;90m'
NC='\033[0m' # No Color

LOCK_FILE="lazy-lock.json"

# Detect lazy.nvim installation path
DATA_PATH=$(nvim --headless -E -u NONE '+lua print(vim.fn.stdpath("data"))' +q 2>&1)
LAZY_PATH="$DATA_PATH/lazy"

echo "${BLUE}${BOLD}==> Updating Mason tools & registries...${NC}"
nvim --headless "+MasonToolsUpdateSync" +qa > /dev/null 2>&1

echo "${BLUE}${BOLD}==> Starting Neovim plugin update...${NC}"
nvim --headless "+Lazy! sync" +qa > /dev/null 2>&1

if git diff --quiet -- "$LOCK_FILE"; then
    echo "${GREEN}No changes detected. All plugins are up to date.${NC}"
else
    echo "\n${YELLOW}${BOLD}Plugin Update Summary:${NC}"
    echo "========================================"
    
    # Compare the lock file as JSON instead of trying to pair raw diff lines.
    # This avoids bogus plugin names when multiple entries change, are added, or are removed.
    while IFS=$'\t' read -r name old_hash new_hash status; do
        # Display Plugin Name and Short Hashes
        short_old=${old_hash:0:7}
        short_new=${new_hash:0:7}
        if [ "$status" = "added" ]; then
            short_old="(new)"
        elif [ "$status" = "removed" ]; then
            short_new="(removed)"
        fi
        printf "${BLUE}${BOLD}%-30s${NC} ${GRAY}%s -> %s${NC}\n" \
            "$name" "$short_old" "$short_new"

        # Attempt to show git logs for updated plugins
        plugin_dir="$LAZY_PATH/$name"
        if [ "$status" = "updated" ] && [ -d "$plugin_dir" ]; then
            git -C "$plugin_dir" log --oneline --no-decorate --color=always \
                ${old_hash}..${new_hash} 2>/dev/null | sed 's/^/    /'
        elif [ "$status" = "updated" ]; then
            echo "    ${GRAY}(Plugin directory not found, skipping logs)${NC}"
        fi
        echo ""
    done < <(python3 - "$LOCK_FILE" <<'PY'
import json
import subprocess
import sys

lock_file = sys.argv[1]

old_text = subprocess.check_output(["git", "show", f"HEAD:{lock_file}"], text=True)
with open(lock_file, encoding="utf-8") as f:
    new_text = f.read()

old = json.loads(old_text)
new = json.loads(new_text)

for name in sorted(set(old) | set(new)):
    old_hash = old.get(name, {}).get("commit", "")
    new_hash = new.get(name, {}).get("commit", "")
    if old_hash == new_hash:
        continue
    if name not in old:
        status = "added"
    elif name not in new:
        status = "removed"
    else:
        status = "updated"
    print(f"{name}\t{old_hash}\t{new_hash}\t{status}")
PY
    )

    echo "========================================"

    # Commit the changes
    git add "$LOCK_FILE"
    git commit -m "chore: update lazy lock"
    echo "${GREEN}${BOLD}✔ $LOCK_FILE updated and committed successfully.${NC}"
fi
